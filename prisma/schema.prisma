// logr — Postgres (Supabase) schema.
// JSON-shaped fields (socials, theme, link) are stored as serialized strings.
// Phase 3 adds pgvector for the chat RAG index.
//
// Supabase needs two connection strings:
//   DATABASE_URL — pooled (PgBouncer, :6543, ?pgbouncer=true) for the app at runtime
//   DIRECT_URL   — direct (:5432) for `prisma migrate`, which PgBouncer can't run

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Profile {
  id        String   @id @default(cuid())
  userId    String?  @unique // the owning account (null for the legacy single-user profile)
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  username  String   @unique
  name      String
  handle    String
  bio       String
  status    String // current "building X" line
  location  String
  about     String? // longer-form prose for the "A little more" section
  avatarUrl String?
  socials   String // JSON: [{ label, href }]
  theme     String // JSON: { palette, fonts, rounded, accentOverride, postStyle, dotStyle, photoHover, dark }

  events       Event[]
  chatMessages ChatMessage[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ---------- Auth.js (NextAuth) ----------
model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
  profile       Profile?
  createdAt     DateTime  @default(now())
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Event {
  id        String  @id @default(cuid())
  profileId String
  profile   Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  dateOn   String // the event date, ISO "YYYY-MM-DD"; display + year are derived
  title    String
  tags     String[] @default([]) // work | milestone | talk | side_quest | writing (multiple)
  body     String
  icon     String? // optional glyph/emoji shown on the timeline dot
  featured Boolean  @default(true) // include in the "highlights" view on the page
  fullDate Boolean  @default(false) // show the exact day on the timeline (else month + year)

  linkLabel String?
  linkHref  String?

  position Int // explicit ordering (reverse-chronological)

  media Media[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([profileId, position])
}

model Media {
  id       String  @id @default(cuid())
  eventId  String
  event    Event   @relation(fields: [eventId], references: [id], onDelete: Cascade)
  kind     String  @default("image") // image | video | link
  url      String? // image/video file URL, provider embed URL, or external link; null = placeholder
  poster   String? // thumbnail/poster image (video frame, or og:image for links)
  provider String? // file | youtube | vimeo | loom | site name (for links)
  title    String? // card title (og:title for links)
  position Int

  @@index([eventId, position])
}

model ChatMessage {
  id        String   @id @default(cuid())
  profileId String
  profile   Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  sessionId String // groups a visitor's conversation
  role      String // user | assistant
  content   String
  visitor   String? // hashed IP, for light abuse analytics (never raw)
  createdAt DateTime @default(now())

  @@index([profileId, createdAt])
}
