// logr — Postgres (Supabase) schema.
// JSON-shaped fields (socials, theme, link) are stored as serialized strings.
// Phase 3 adds pgvector for the chat RAG index.
//
// Supabase needs two connection strings:
//   DATABASE_URL — pooled (PgBouncer, :6543, ?pgbouncer=true) for the app at runtime
//   DIRECT_URL   — direct (:5432) for `prisma migrate`, which PgBouncer can't run

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Profile {
  id        String   @id @default(cuid())
  username  String   @unique
  name      String
  handle    String
  bio       String
  status    String // current "building X" line
  location  String
  about     String? // longer-form prose for the "A little more" section
  avatarUrl String?
  socials   String // JSON: [{ label, href }]
  theme     String // JSON: { palette, fonts, rounded, accentOverride, postStyle, dotStyle, photoHover, dark }

  events       Event[]
  chatMessages ChatMessage[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Event {
  id        String  @id @default(cuid())
  profileId String
  profile   Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  date     String // display string, e.g. "Nov 2025" or "2014 — 2016"
  year     Int // for year grouping
  title    String
  tags     String[] @default([]) // work | milestone | talk | side_quest | writing (multiple)
  body     String
  icon     String? // optional glyph/emoji shown on the timeline dot
  featured Boolean  @default(true) // include in the "highlights" view on the page

  linkLabel String?
  linkHref  String?

  position Int // explicit ordering (reverse-chronological)

  media Media[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([profileId, position])
}

model Media {
  id       String  @id @default(cuid())
  eventId  String
  event    Event   @relation(fields: [eventId], references: [id], onDelete: Cascade)
  kind     String  @default("image") // image | video
  url      String? // image/video file URL, or a provider embed URL; null = empty placeholder
  poster   String? // thumbnail/poster image for videos
  provider String? // file | youtube | vimeo | loom (null for plain images)
  position Int

  @@index([eventId, position])
}

model ChatMessage {
  id        String   @id @default(cuid())
  profileId String
  profile   Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  sessionId String // groups a visitor's conversation
  role      String // user | assistant
  content   String
  visitor   String? // hashed IP, for light abuse analytics (never raw)
  createdAt DateTime @default(now())

  @@index([profileId, createdAt])
}
